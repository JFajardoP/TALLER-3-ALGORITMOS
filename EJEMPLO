    def manual(self):
        try:
            # Obtener X y Y de la interfaz
            px = float(self.textEdit.toPlainText())
            py = float(self.textEdit_2.toPlainText())

            # Uso de TU librería de cinemática inversa
            # Asumo que devuelve q1, q2 en grados o radianes
            q1, q2 = InverseKinematics2R(px, py, l1, l2)

            # Mover Servos
            if SERVO_1 and SERVO_2:
                SERVO_1.angle = q1
                SERVO_2.angle = q2

            # Visualización URDF
            if self.robot_urdf:
                # Se pasan los ángulos en radianes al visualizador
                cfg = {
                    'joint1': numpy.deg2rad(q1),
                    'joint2': numpy.deg2rad(q2)
                }
                self.robot_urdf.show(cfg=cfg)

        except Exception as e:
            print(f"Error en movimiento: {e}")

